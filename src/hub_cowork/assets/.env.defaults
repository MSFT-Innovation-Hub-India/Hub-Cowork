# ─────────────────────────────────────────────────────────────────────────────
# Hub Cowork — packaged default environment values.
#
# These ship with the app so a fresh install starts with sensible, working
# defaults for the public/non-secret values. Loaded with the LOWEST priority:
#
#   1. _env_overrides from hub_config.json   (set via Settings UI)
#   2. user .env in the current directory    (developer/operator overrides)
#   3. THIS FILE                              (shipped defaults — fallback)
#
# Anything you set in either of the higher tiers wins. Edit values via the
# Settings → "Environment & secrets" panel rather than this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI ──
AZURE_OPENAI_ENDPOINT=https://rob-agent-aoai.openai.azure.com/openai/v1
AZURE_OPENAI_CHAT_MODEL=gpt-5.2
AZURE_OPENAI_CHAT_MODEL_SMALL=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# ── Email (Azure Communication Services) ──
ACS_ENDPOINT=https://pcdotai-comms.india.communication.azure.com
ACS_SENDER_ADDRESS=DoNotReply@ocvp-msft-india.com

# ── RFP Evaluation — FoundryIQ ──
FOUNDRYIQ_KB_NAME=rfp-knowledge-store
FOUNDRYIQ_AUTH_MODE=browser
FOUNDRYIQ_API_VERSION=2025-11-01-preview

# ── RFP Evaluation — Foundry Agent ──
FOUNDRY_AGENT_NAME=project-analysis-agent
FOUNDRY_AUTH_MODE=browser

# ── Redis (optional) ──
REDIS_NAMESPACE=hub-cowork
REDIS_SESSION_TTL_SECONDS=86400
