# ─────────────────────────────────────────────────────────────────────────────
# Hub Cowork — packaged default environment values.
#
# These ship with the app so a fresh install starts with sensible, working
# defaults for the SHARED team infrastructure (same Azure OpenAI deployment,
# same ACS resource, same Redis cache, same FoundryIQ + Fabric agents).
# Loaded with the LOWEST priority:
#
#   1. _env_overrides from hub_config.json   (set via Settings → Configuration)
#   2. user .env in the current directory    (developer/operator overrides)
#   3. THIS FILE                              (shipped defaults — fallback)
#
# PER-USER values (NOT shipped here — every user MUST set these themselves
# via Settings → Configuration on first run):
#   - RFP_OUTPUT_FOLDER     (your local OneDrive path for generated docs)
#   - RFP_SHARE_RECIPIENTS  (your team's reviewer email list)
#
# Note on email: ACS_SENDER_ADDRESS is the SHARED DoNotReply mailbox
# (verified on the ACS resource). Recipients see Reply-To set to the
# logged-in user's address (resolved at send time from their Entra
# token), and calendar invites carry that user as the ORGANIZER.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure tenancy / subscription (shared) ──
AZURE_TENANT_ID=16b3c013-d300-468d-ac64-7eda0820b6d3
AZURE_SUBSCRIPTION_ID=bc2e2415-164d-45a5-9a4a-29d9264a343e

# ── Azure OpenAI (shared) ──
AZURE_OPENAI_ENDPOINT=https://rob-agent-aoai.openai.azure.com/openai/v1
AZURE_OPENAI_CHAT_MODEL=gpt-5.2
AZURE_OPENAI_CHAT_MODEL_SMALL=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# ── Email (Azure Communication Services — shared resource) ──
# Both endpoint and sender are shared. Reply-To is set per-call to the
# logged-in user's email so recipients reply to the actual user.
ACS_ENDPOINT=https://pcdotai-comms.india.communication.azure.com
ACS_SENDER_ADDRESS=DoNotReply@ocvp-msft-india.com

# ── Teams bridge (Azure Managed Redis — shared) ──
AZ_REDIS_CACHE_ENDPOINT=ocvp-cache.southindia.redis.azure.net:10000
REDIS_NAMESPACE=hub-cowork
REDIS_SESSION_TTL_SECONDS=86400

# ── RFP Evaluation — FoundryIQ (shared knowledge store) ──
FOUNDRYIQ_ENDPOINT=https://rfp-foundryiq-search.search.windows.net
FOUNDRYIQ_KB_NAME=rfp-knowledge-store
FOUNDRYIQ_AUTH_MODE=browser
FOUNDRYIQ_API_VERSION=2025-11-01-preview

# ── RFP Evaluation — Fabric Data Agent (shared agent in resource tenant) ──
FABRIC_DATA_AGENT_URL=https://api.fabric.microsoft.com/v1/workspaces/98a9f9d7-8b4d-4ddf-b6ca-cec0708675fd/dataagents/26a0ce87-6471-47fb-85ab-5ec895c7f007/aiassistant/openai
RESOURCE_TENANT_ID=3002da77-1cfa-43b6-86eb-c81310c443c6
FABRIC_AUTH_MODE=browser
FABRIC_API_VERSION=2024-05-01-preview
FABRIC_POLL_TIMEOUT=600
FABRIC_POLL_INTERVAL=3
